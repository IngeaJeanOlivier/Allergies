    "\n",
    "rfc = RandomForestClassifier()\n",
    "\n",
    "rfc.fit(X=X_train, y=y_train)\n",
    "\n",
    "score = rfc.score(X=X_test, y=y_test)\n",
    "\n",
    "print(score)"
   ]
