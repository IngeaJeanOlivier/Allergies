    "db_path = \"../data/allergen_chip_challenge.db\"\n",
    "\n",
    "# On va lire les données allergies directement depuis la table dans la base de données :\n",
    "conn = sqlite3.connect(db_path)\n",
    "\n",
    "df = pd.read_sql(\"Select * From allergies\", conn)\n",
    "conn.close()\n",
    "\n",
    "df.shape"
   ]
