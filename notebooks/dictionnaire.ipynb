# Définition exacte du dictionnaire de correspondance (Mapping)
mapping_categories = {
    # 1. POLLENS D'ARBRES (Tree Pollens)
    'Aln_g_1': 'Tree_Pollens', 'Bet_v_1': 'Tree_Pollens', 'Bet_v_2': 'Tree_Pollens', 'Bet_v_4': 'Tree_Pollens',
